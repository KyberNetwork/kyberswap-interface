{
  "name": "kyberswap-og-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare edge worker for KyberSwap dynamic social-preview (OG) cards: per-request <head> meta injection for swap/limit pairs + 1200x630 PNG generation.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "type-check": "wrangler types && tsc --noEmit",
    "test": "esbuild test/smoke.ts --bundle --platform=node --format=esm --tsconfig=tsconfig.json --outfile=.test-bundle.mjs && node .test-bundle.mjs"
  },
  "dependencies": {
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.20.0"
  }
}
